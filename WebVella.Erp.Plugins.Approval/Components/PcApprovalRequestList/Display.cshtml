    }
</style>

@* Reference external service.js for page builder lifecycle events *@
<script src="/_content/WebVella.Erp.Plugins.Approval/Components/PcApprovalRequestList/service.js"></script>

@* Inline Action Scripts *@
<script type="text/javascript">
    /**
     * Opens the approve modal and sets the request ID
     */
    function openInlineApproveModal(requestId) {
        document.getElementById('inlineApproveRequestId').value = requestId;
        document.getElementById('inlineApproveComments').value = '';
        
        var modalElement = document.getElementById('inlineApproveModal');
        if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
            var modal = new bootstrap.Modal(modalElement);
            modal.show();
        } else if (typeof $ !== 'undefined' && $.fn.modal) {
            $(modalElement).modal('show');
        }
    }
    
    /**
     * Opens the reject modal and sets the request ID
     */
    function openInlineRejectModal(requestId) {
        document.getElementById('inlineRejectRequestId').value = requestId;
        document.getElementById('inlineRejectReason').value = '';
        document.getElementById('inlineRejectReason').classList.remove('is-invalid');
        document.getElementById('inlineRejectComments').value = '';
        
        var modalElement = document.getElementById('inlineRejectModal');
        if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
            var modal = new bootstrap.Modal(modalElement);
            modal.show();
        } else if (typeof $ !== 'undefined' && $.fn.modal) {
            $(modalElement).modal('show');
        }
    }
    
    /**
     * Submits the inline approve action
     */
    function submitInlineApprove() {
        var requestId = document.getElementById('inlineApproveRequestId').value;
        var comments = document.getElementById('inlineApproveComments').value.trim();
        
        if (!requestId) {
            console.error('No request ID found for approval');
            return;
        }
        
        performInlineAction(
            '/api/v3.0/p/approval/request/' + requestId + '/approve',
            { comments: comments },
            'inlineApproveModal',
            'Request approved successfully!'
        );
    }
    
    /**
     * Submits the inline reject action
     */
    function submitInlineReject() {
        var requestId = document.getElementById('inlineRejectRequestId').value;
        var reasonField = document.getElementById('inlineRejectReason');
        var reason = reasonField.value.trim();
        var comments = document.getElementById('inlineRejectComments').value.trim();
        
        if (!requestId) {
            console.error('No request ID found for rejection');
            return;
        }
        
        // Validate required reason field
        if (!reason) {
            reasonField.classList.add('is-invalid');
            reasonField.focus();
            return;
        }
        reasonField.classList.remove('is-invalid');
        
        performInlineAction(
            '/api/v3.0/p/approval/request/' + requestId + '/reject',
            { reason: reason, comments: comments },
            'inlineRejectModal',
            'Request rejected.'
        );
    }
    
    /**
     * Performs an inline approval/rejection action via AJAX
     */
    function performInlineAction(url, data, modalId, successMessage) {
        var btn = document.querySelector('#' + modalId + ' .modal-footer .btn-success, #' + modalId + ' .modal-footer .btn-danger');
        var originalHtml = btn ? btn.innerHTML : '';
        
        if (btn) {
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i>Processing...';
        }
        
        fetch(url, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Accept': 'application/json'
            },
            body: JSON.stringify(data)
        })
        .then(function(response) {
            if (!response.ok) {
                return response.json().then(function(err) {
                    throw new Error(err.message || 'An error occurred');
                });
            }
            return response.json();
        })
        .then(function(result) {
            // Close the modal
            var modalElement = document.getElementById(modalId);
            if (modalElement) {
                if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
                    var modalInstance;
                    // Check if getInstance method exists (Bootstrap 5.1.0+)
                    if (typeof bootstrap.Modal.getInstance === 'function') {
                        modalInstance = bootstrap.Modal.getInstance(modalElement);
                    }
                    // If no existing instance, create a new one
                    if (!modalInstance) {
                        modalInstance = new bootstrap.Modal(modalElement);
                    }
                    modalInstance.hide();
                } else if (typeof $ !== 'undefined') {
                    // Fallback to jQuery if Bootstrap 5 is not available
                    $(modalElement).modal('hide');
                }
            }
            
            // Show success message
            if (typeof toastr !== 'undefined') {
                toastr.success(successMessage);
            } else {
                alert(successMessage);
            }
            
            // Refresh the page to show updated status
            setTimeout(function() {
                window.location.reload();
            }, 1000);
        })
        .catch(function(error) {
            console.error('Inline action error:', error);
            
            // Show error message
            if (typeof toastr !== 'undefined') {
                toastr.error(error.message || 'An error occurred while processing your request.');
            } else {
                alert('Error: ' + (error.message || 'An error occurred while processing your request.'));
            }
            
            // Re-enable the button
            if (btn) {
                btn.disabled = false;
                btn.innerHTML = originalHtml;
            }
        });
    }
</script>

@* Auto-refresh Script Integration *@
@if (options.AutoRefresh)
{
    <script type="text/javascript">
        (function() {
            // Auto-refresh functionality for approval request list
            var componentId = '@componentId';
            var refreshInterval = 60000; // 60 seconds default refresh interval
            
            function refreshApprovalList() {
                // Trigger page reload to refresh the list
                // In a more sophisticated implementation, this would use AJAX
                if (document.visibilityState === 'visible') {
                    window.location.reload();
                }
            }
            
            // Set up auto-refresh interval
            var intervalId = setInterval(refreshApprovalList, refreshInterval);
            
            // Clean up interval when component is removed
            var component = document.getElementById(componentId);
            if (component) {
                // Use MutationObserver to detect when component is removed
                var observer = new MutationObserver(function(mutations) {
                    if (!document.body.contains(component)) {
                        clearInterval(intervalId);
                        observer.disconnect();
                    }
                });
                observer.observe(document.body, { childList: true, subtree: true });
            }
        })();
    </script>
}
