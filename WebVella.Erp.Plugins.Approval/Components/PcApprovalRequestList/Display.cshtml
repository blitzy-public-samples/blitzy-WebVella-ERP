@*
    Display.cshtml - Runtime display view for PcApprovalRequestList component.
    
    Renders a filterable, paginated list of pending approval requests including:
    - Request ID
    - Workflow name
    - Source entity name
    - Status (with badge styling)
    - Requested by user
    - Requested date
    - Current step
    - Action links
    
    Uses WebVella grid components and tag helpers for consistent UI rendering.
    Supports filter form submission and optional auto-refresh via service.js integration.
*@
@addTagHelper *, WebVella.Erp.Plugins.Core
@addTagHelper *, WebVella.Erp.Web
@addTagHelper *, WebVella.TagHelpers
@using WebVella.Erp.Web.Models
@using WebVella.Erp.Api.Models
@using WebVella.Erp.Web.Utils
@using WebVella.Erp.Plugins.Approval.Components
@using WebVella.TagHelpers.Models
@{
    // Extract component options from ViewBag
    var options = (PcApprovalRequestList.PcApprovalRequestListOptions)ViewBag.Options;
    
    // Extract records list - may be empty if no pending approvals
    var records = ViewBag.Records as List<EntityRecord> ?? new List<EntityRecord>();
    
    // Extract pagination data
    var totalCount = ViewBag.TotalCount != null ? (int)ViewBag.TotalCount : 0;
    var pageSize = ViewBag.PageSize != null ? (int)ViewBag.PageSize : 10;
    var currentPage = ViewBag.CurrentPage != null ? (int)ViewBag.CurrentPage : 1;
    var totalPages = ViewBag.TotalPages != null ? (int)ViewBag.TotalPages : 1;
    var hasPreviousPage = ViewBag.HasPreviousPage != null ? (bool)ViewBag.HasPreviousPage : false;
    var hasNextPage = ViewBag.HasNextPage != null ? (bool)ViewBag.HasNextPage : false;
    
    // Extract pager data
    var pager = ViewBag.Pager as EntityRecord;
    var visiblePages = pager != null && pager.Properties.ContainsKey("visible_pages") 
        ? pager["visible_pages"] as List<int> ?? new List<int>() 
        : new List<int>();
    var showFirstEllipsis = pager != null && pager.Properties.ContainsKey("show_first_ellipsis") 
        ? (bool)pager["show_first_ellipsis"] 
        : false;
    var showLastEllipsis = pager != null && pager.Properties.ContainsKey("show_last_ellipsis") 
        ? (bool)pager["show_last_ellipsis"] 
        : false;
    
    // Get site root URL for building links
    var siteRootUrl = ViewBag.SiteRootUrl as string ?? "";
    
    // Define grid columns for the approval request list
    var gridColumns = new List<WvGridColumnMeta>
    {
        new WvGridColumnMeta { Name = "action", Label = "", Width = "50px" },
        new WvGridColumnMeta { Name = "workflow_name", Label = "Workflow", Width = "" },
        new WvGridColumnMeta { Name = "source_entity", Label = "Source Entity", Width = "150px" },
        new WvGridColumnMeta { Name = "status", Label = "Status", Width = "100px" },
        new WvGridColumnMeta { Name = "requested_by", Label = "Requested By", Width = "150px" },
        new WvGridColumnMeta { Name = "requested_on", Label = "Requested On", Width = "150px" },
        new WvGridColumnMeta { Name = "current_step", Label = "Current Step", Width = "150px" }
    };
    
    // Status options for filter dropdown
    var statusOptions = new List<SelectOption>
    {
        new SelectOption { Value = "", Label = "All Statuses" },
        new SelectOption { Value = "pending", Label = "Pending" },
        new SelectOption { Value = "approved", Label = "Approved" },
        new SelectOption { Value = "rejected", Label = "Rejected" },
        new SelectOption { Value = "escalated", Label = "Escalated" },
        new SelectOption { Value = "expired", Label = "Expired" }
    };
    
    // Generate unique component ID for JavaScript targeting
    var componentId = "approval-request-list-" + Guid.NewGuid().ToString("N").Substring(0, 8);
}

<div id="@componentId" class="pc-approval-request-list" data-auto-refresh="@options.AutoRefresh.ToString().ToLower()">
    @* Filter Section *@
    <div class="card mb-3">
        <div class="card-body p-2">
            <form method="get" class="form-inline approval-filter-form">
                <div class="row w-100 align-items-end">
                    @* Status Filter Dropdown *@
                    <div class="col-md-2 mb-2 mb-md-0">
                        <label class="small text-muted d-block">Status</label>
                        <select name="status" class="form-control form-control-sm w-100">
                            @foreach (var statusOption in statusOptions)
                            {
                                var isSelected = statusOption.Value == (options.StatusFilter ?? "");
                                if (isSelected)
                                {
                                    <option value="@statusOption.Value" selected>@statusOption.Label</option>
                                }
                                else
                                {
                                    <option value="@statusOption.Value">@statusOption.Label</option>
                                }
                            }
                        </select>
                    </div>
                    
                    @* Date From Filter *@
                    <div class="col-md-2 mb-2 mb-md-0">
                        <label class="small text-muted d-block">From Date</label>
                        <input type="date" name="date_from" class="form-control form-control-sm w-100" />
                    </div>
                    
                    @* Date To Filter *@
                    <div class="col-md-2 mb-2 mb-md-0">
                        <label class="small text-muted d-block">To Date</label>
                        <input type="date" name="date_to" class="form-control form-control-sm w-100" />
                    </div>
                    
                    @* Search Input *@
                    <div class="col-md-3 mb-2 mb-md-0">
                        <label class="small text-muted d-block">Search</label>
                        <input type="text" name="search" class="form-control form-control-sm w-100" placeholder="Search requests..." />
                    </div>
                    
                    @* Filter Buttons *@
                    <div class="col-md-3 mb-2 mb-md-0">
                        <label class="small text-muted d-block">&nbsp;</label>
                        <button type="submit" class="btn btn-primary btn-sm mr-1">
                            <i class="fas fa-filter"></i> Filter
                        </button>
                        <a href="?" class="btn btn-outline-secondary btn-sm">
                            <i class="fas fa-times"></i> Clear
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>
    
    @* Summary Row *@
    <div class="d-flex justify-content-between align-items-center mb-2">
        <div class="text-muted small">
            @if (totalCount > 0)
            {
                var startRecord = ((currentPage - 1) * pageSize) + 1;
                var endRecord = Math.Min(currentPage * pageSize, totalCount);
                <span>Showing @startRecord - @endRecord of @totalCount requests</span>
            }
            else
            {
                <span>No requests found</span>
            }
        </div>
        @if (options.AutoRefresh)
        {
            <div class="text-muted small">
                <i class="fas fa-sync-alt fa-spin mr-1"></i>
                <span class="auto-refresh-indicator">Auto-refresh enabled</span>
            </div>
        }
    </div>
    
    @* Request List Grid *@
    @if (records.Count > 0)
    {
        <wv-grid bordered="true" hover="true" small="true" columns="@gridColumns" has-tfoot="false" striped="true">
            @foreach (var record in records)
            {
                // Extract record properties with null-safe access
                var recordId = record.Properties.ContainsKey("id") && record["id"] != null 
                    ? record["id"].ToString() 
                    : "";
                var workflowName = record.Properties.ContainsKey("workflow_name") && record["workflow_name"] != null 
                    ? record["workflow_name"].ToString() 
                    : "Unknown";
                var sourceEntityName = record.Properties.ContainsKey("source_entity") && record["source_entity"] != null 
                    ? record["source_entity"].ToString() 
                    : "N/A";
                var sourceRecordId = record.Properties.ContainsKey("source_record_id") && record["source_record_id"] != null 
                    ? record["source_record_id"].ToString() 
                    : "";
                var status = record.Properties.ContainsKey("status") && record["status"] != null 
                    ? record["status"].ToString() 
                    : "unknown";
                var statusBadgeClass = record.Properties.ContainsKey("status_badge_class") && record["status_badge_class"] != null 
                    ? record["status_badge_class"].ToString() 
                    : "badge-secondary";
                var requestedByUsername = record.Properties.ContainsKey("requested_by_username") && record["requested_by_username"] != null 
                    ? record["requested_by_username"].ToString() 
                    : "Unknown";
                var requestedOnFormatted = record.Properties.ContainsKey("requested_on_formatted") && record["requested_on_formatted"] != null 
                    ? record["requested_on_formatted"].ToString() 
                    : "N/A";
                var currentStepName = record.Properties.ContainsKey("current_step_name") && record["current_step_name"] != null 
                    ? record["current_step_name"].ToString() 
                    : "N/A";
                
                <wv-grid-row>
                    @* Action Column - View Details Link *@
                    <wv-grid-column width="50px" class="text-center">
                        <a href="@siteRootUrl/approval/request/@recordId" class="btn btn-sm btn-outline-primary" title="View Request Details">
                            <i class="fas fa-eye"></i>
                        </a>
                    </wv-grid-column>
                    
                    @* Workflow Name Column *@
                    <wv-grid-column>
                        <span class="font-weight-bold">@workflowName</span>
                        @if (!string.IsNullOrEmpty(sourceRecordId))
                        {
                            <br />
                            <small class="text-muted">Record: @sourceRecordId.Substring(0, Math.Min(8, sourceRecordId.Length))...</small>
                        }
                    </wv-grid-column>
                    
                    @* Source Entity Column *@
                    <wv-grid-column width="150px">
                        <span class="text-capitalize">@sourceEntityName.Replace("_", " ")</span>
                    </wv-grid-column>
                    
                    @* Status Column with Badge *@
                    <wv-grid-column width="100px">
                        <span class="badge @statusBadgeClass text-capitalize">@status</span>
                    </wv-grid-column>
                    
                    @* Requested By Column *@
                    <wv-grid-column width="150px">
                        <i class="fas fa-user mr-1 text-muted"></i>
                        @requestedByUsername
                    </wv-grid-column>
                    
                    @* Requested On Column *@
                    <wv-grid-column width="150px">
                        <i class="far fa-calendar-alt mr-1 text-muted"></i>
                        @requestedOnFormatted
                    </wv-grid-column>
                    
                    @* Current Step Column *@
                    <wv-grid-column width="150px">
                        <i class="fas fa-tasks mr-1 text-muted"></i>
                        @currentStepName
                    </wv-grid-column>
                </wv-grid-row>
            }
        </wv-grid>
    }
    else
    {
        @* Empty State Message *@
        <div class="alert alert-info m-0">
            <i class="fas fa-info-circle mr-2"></i>
            @if (!string.IsNullOrEmpty(options.StatusFilter) && options.StatusFilter != "pending")
            {
                <span>No @options.StatusFilter approval requests found.</span>
            }
            else if (options.ShowMyRequestsOnly)
            {
                <span>You have no pending approval requests assigned to you.</span>
            }
            else
            {
                <span>No pending approval requests found. New requests will appear here when submitted.</span>
            }
        </div>
    }
    
    @* Pagination Controls *@
    @if (totalPages > 1)
    {
        <nav aria-label="Approval request list pagination" class="mt-3">
            <ul class="pagination pagination-sm justify-content-center mb-0">
                @* First Page Button *@
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link" href="?page=1" aria-label="First" title="First Page">
                        <i class="fas fa-angle-double-left"></i>
                    </a>
                </li>
                
                @* Previous Page Button *@
                <li class="page-item @(!hasPreviousPage ? "disabled" : "")">
                    <a class="page-link" href="?page=@(currentPage - 1)" aria-label="Previous" title="Previous Page">
                        <i class="fas fa-angle-left"></i>
                    </a>
                </li>
                
                @* First Page Number (if not visible) *@
                @if (showFirstEllipsis)
                {
                    <li class="page-item">
                        <a class="page-link" href="?page=1">1</a>
                    </li>
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }
                
                @* Visible Page Numbers *@
                @foreach (var pageNum in visiblePages)
                {
                    <li class="page-item @(pageNum == currentPage ? "active" : "")">
                        <a class="page-link" href="?page=@pageNum">@pageNum</a>
                    </li>
                }
                
                @* Last Page Number (if not visible) *@
                @if (showLastEllipsis)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                    <li class="page-item">
                        <a class="page-link" href="?page=@totalPages">@totalPages</a>
                    </li>
                }
                
                @* Next Page Button *@
                <li class="page-item @(!hasNextPage ? "disabled" : "")">
                    <a class="page-link" href="?page=@(currentPage + 1)" aria-label="Next" title="Next Page">
                        <i class="fas fa-angle-right"></i>
                    </a>
                </li>
                
                @* Last Page Button *@
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link" href="?page=@totalPages" aria-label="Last" title="Last Page">
                        <i class="fas fa-angle-double-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
        
        @* Page Info Summary *@
        <div class="text-center mt-2">
            <small class="text-muted">Page @currentPage of @totalPages</small>
        </div>
    }
</div>

@* Inline Styles for Component *@
<style>
    .pc-approval-request-list .badge {
        font-size: 0.75rem;
        padding: 0.35em 0.65em;
    }
    .pc-approval-request-list .badge-warning {
        background-color: #ffc107;
        color: #212529;
    }
    .pc-approval-request-list .badge-success {
        background-color: #28a745;
        color: #fff;
    }
    .pc-approval-request-list .badge-danger {
        background-color: #dc3545;
        color: #fff;
    }
    .pc-approval-request-list .badge-info {
        background-color: #17a2b8;
        color: #fff;
    }
    .pc-approval-request-list .badge-secondary {
        background-color: #6c757d;
        color: #fff;
    }
    .pc-approval-request-list .approval-filter-form .form-control-sm {
        height: calc(1.5em + 0.5rem + 2px);
        font-size: 0.875rem;
    }
    .pc-approval-request-list .auto-refresh-indicator {
        font-style: italic;
    }
</style>

@* Reference external service.js for page builder lifecycle events *@
<script src="/_content/WebVella.Erp.Plugins.Approval/Components/PcApprovalRequestList/service.js"></script>

@* Auto-refresh Script Integration *@
@if (options.AutoRefresh)
{
    <script type="text/javascript">
        (function() {
            // Auto-refresh functionality for approval request list
            var componentId = '@componentId';
            var refreshInterval = 60000; // 60 seconds default refresh interval
            
            function refreshApprovalList() {
                // Trigger page reload to refresh the list
                // In a more sophisticated implementation, this would use AJAX
                if (document.visibilityState === 'visible') {
                    window.location.reload();
                }
            }
            
            // Set up auto-refresh interval
            var intervalId = setInterval(refreshApprovalList, refreshInterval);
            
            // Clean up interval when component is removed
            var component = document.getElementById(componentId);
            if (component) {
                // Use MutationObserver to detect when component is removed
                var observer = new MutationObserver(function(mutations) {
                    if (!document.body.contains(component)) {
                        clearInterval(intervalId);
                        observer.disconnect();
                    }
                });
                observer.observe(document.body, { childList: true, subtree: true });
            }
        })();
    </script>
}
