@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, WebVella.Erp.Web
@addTagHelper *, WebVella.TagHelpers
@using WebVella.Erp.Plugins.Approval.Components
@{
    var componentMeta = (WebVella.Erp.Web.Models.PageComponentMeta)ViewBag.ComponentMeta;
}

<div class="component-help">
    <h4><i class="fas fa-chart-line me-2"></i>Approval Dashboard Component</h4>
    
    <p class="lead">
        Real-time dashboard displaying team approval workflow metrics for managers and administrators.
    </p>

    <hr />

    <h5>Overview</h5>
    <p>
        The Approval Dashboard provides visibility into your team's approval workflow performance.
        It displays five key performance indicators (KPIs) that auto-refresh at a configurable interval.
    </p>

    <h5>Key Metrics</h5>
    <ul>
        <li><strong>Pending Approvals Count:</strong> Number of approval requests awaiting your action.</li>
        <li><strong>Average Approval Time:</strong> Mean time from request creation to final decision (in hours).</li>
        <li><strong>Approval Rate:</strong> Percentage of approved requests versus total processed (approved + rejected).</li>
        <li><strong>Overdue Requests:</strong> Count of pending requests exceeding their configured SLA timeout.</li>
        <li><strong>Recent Activity:</strong> Last 5 approval actions with action type, performer, and timestamp.</li>
    </ul>

    <h5>Configuration Options</h5>
    <table class="table table-bordered table-sm">
        <thead class="table-light">
            <tr>
                <th>Option</th>
                <th>Type</th>
                <th>Default</th>
                <th>Description</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td><code>refresh_interval</code></td>
                <td>Number</td>
                <td>60</td>
                <td>Auto-refresh interval in seconds. Set to 0 to disable.</td>
            </tr>
            <tr>
                <td><code>date_range_default</code></td>
                <td>Text</td>
                <td>30d</td>
                <td>Default date range: 7d, 30d, or 90d.</td>
            </tr>
            <tr>
                <td><code>show_overdue_alert</code></td>
                <td>Boolean</td>
                <td>true</td>
                <td>Highlight overdue count with warning styling.</td>
            </tr>
            <tr>
                <td><code>metrics_to_display</code></td>
                <td>Text</td>
                <td>pending,avg_time,approval_rate,overdue,recent</td>
                <td>Comma-separated list of metrics to show.</td>
            </tr>
        </tbody>
    </table>

    <h5>Access Control</h5>
    <p>
        <i class="fas fa-lock text-warning me-2"></i>
        This component requires <strong>Manager</strong> or <strong>Administrator</strong> role to view.
        Users without these roles will see an access denied message.
    </p>

    <h5>API Endpoint</h5>
    <p>
        The dashboard retrieves data from the following endpoint:
    </p>
    <pre class="bg-light p-2 rounded"><code>GET /api/v3.0/p/approval/dashboard/metrics?from={date}&amp;to={date}</code></pre>
    <p>
        <strong>Parameters:</strong>
    </p>
    <ul>
        <li><code>from</code> (optional): Start date in ISO 8601 format. Defaults to 30 days ago.</li>
        <li><code>to</code> (optional): End date in ISO 8601 format. Defaults to current time.</li>
    </ul>

    <h5>JavaScript API</h5>
    <p>
        The dashboard exposes the following JavaScript functions:
    </p>
    <ul>
        <li><code>ApprovalDashboard.init(nodeId, options)</code> - Initialize dashboard with auto-refresh</li>
        <li><code>ApprovalDashboard.refresh(nodeId)</code> - Manually trigger metrics refresh</li>
        <li><code>ApprovalDashboard.changeDateRange(nodeId, range)</code> - Change the date range filter</li>
        <li><code>ApprovalDashboard.stop(nodeId)</code> - Stop auto-refresh timer</li>
    </ul>

    <h5>Version</h5>
    <p>
        <span class="badge bg-primary">v@(componentMeta?.Version ?? "0.0.1")</span>
        <span class="badge bg-secondary">@(componentMeta?.Library ?? "WebVella")</span>
    </p>
</div>
