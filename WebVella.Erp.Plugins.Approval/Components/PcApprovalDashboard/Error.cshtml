@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, WebVella.Erp.Web
@addTagHelper *, WebVella.TagHelpers
@using WebVella.Erp.Web.Utils
@using WebVella.Erp.Exceptions
@{
    var validation = (ValidationException)ViewBag.Error;
    var isAccessDenied = validation?.Message?.Contains("Access denied") ?? false;
}

@if (isAccessDenied)
{
    <!-- Access Denied Error Display -->
    <div class="alert alert-warning border-warning">
        <div class="d-flex align-items-center">
            <div class="me-3">
                <i class="fas fa-lock fa-3x text-warning"></i>
            </div>
            <div>
                <h5 class="alert-heading mb-1">Access Denied</h5>
                <p class="mb-0">@validation.Message</p>
                <hr class="my-2" />
                <small class="text-muted">
                    <i class="fas fa-info-circle me-1"></i>
                    The Approval Dashboard is only available to users with Manager or Administrator role.
                </small>
            </div>
        </div>
    </div>
}
else
{
    <!-- General Error Display -->
    <div class="alert alert-danger border-danger">
        <div class="d-flex align-items-center">
            <div class="me-3">
                <i class="fas fa-exclamation-triangle fa-3x text-danger"></i>
            </div>
            <div>
                <h5 class="alert-heading mb-1">Error</h5>
                <wv-validation errors="@validation.ToErrorList()" message="@validation.Message"></wv-validation>
            </div>
        </div>
    </div>
}
