@addTagHelper *, WebVella.Erp.Web
@addTagHelper *, WebVella.TagHelpers
@using WebVella.Erp.Web.Utils
@using WebVella.Erp.Web
@using WebVella.Erp.Web.Models
@using WebVella.TagHelpers.Models
@using WebVella.Erp.Plugins.Approval.Components
@{
    var options = (PcApprovalDashboard.PcApprovalDashboardOptions)ViewBag.Options;
    
    // Build date range options for select
    var dateRangeOptions = new List<WvSelectOption>
    {
        new WvSelectOption { Value = "7d", Label = "Last 7 Days" },
        new WvSelectOption { Value = "30d", Label = "Last 30 Days" },
        new WvSelectOption { Value = "90d", Label = "Last 90 Days" }
    };
}

<div class="pc-approval-dashboard-options">
    <!-- General Settings Section -->
    <div class="card mb-3">
        <div class="card-header py-2">
            <h6 class="mb-0"><i class="fas fa-cog mr-2"></i>General Settings</h6>
        </div>
        <div class="card-body">
            <wv-row>
                <wv-column span="6">
                    <wv-field-text 
                        name="dashboard_title" 
                        value="@options.DashboardTitle" 
                        label-text="Dashboard Title"
                        description="Custom title displayed at the top of the dashboard. Leave empty for default.">
                    </wv-field-text>
                </wv-column>
                <wv-column span="6">
                    <wv-field-number 
                        name="refresh_interval" 
                        value="@options.RefreshInterval" 
                        label-text="Auto-Refresh Interval (seconds)"
                        min="30"
                        description="How often the dashboard metrics should auto-refresh. Minimum 30 seconds.">
                    </wv-field-number>
                </wv-column>
            </wv-row>
        </div>
    </div>

    <!-- Date Range Settings Section -->
    <div class="card mb-3">
        <div class="card-header py-2">
            <h6 class="mb-0"><i class="fas fa-calendar-alt mr-2"></i>Date Range Settings</h6>
        </div>
        <div class="card-body">
            <wv-row>
                <wv-column span="6">
                    <wv-field-select 
                        name="date_range_default" 
                        value="@options.DateRangeDefault" 
                        label-text="Default Date Range"
                        options="@dateRangeOptions"
                        description="The default date range for displaying metrics when the dashboard loads.">
                    </wv-field-select>
                </wv-column>
            </wv-row>
        </div>
    </div>

    <!-- Display Settings Section -->
    <div class="card mb-3">
        <div class="card-header py-2">
            <h6 class="mb-0"><i class="fas fa-eye mr-2"></i>Display Settings</h6>
        </div>
        <div class="card-body">
            <wv-row>
                <wv-column span="12">
                    <wv-field-text 
                        name="metrics_to_display" 
                        value="@options.MetricsToDisplay" 
                        label-text="Metrics to Display"
                        description="Comma-separated list of metrics to show. Options: pending, avg_time, approval_rate, overdue, recent">
                    </wv-field-text>
                </wv-column>
            </wv-row>
            <wv-row class="mt-3">
                <wv-column span="6">
                    <wv-field-checkbox 
                        name="show_overdue_alert" 
                        value="@options.ShowOverdueAlert" 
                        text="Highlight Overdue Requests"
                        description="Show a visual alert indicator when there are overdue approval requests.">
                    </wv-field-checkbox>
                </wv-column>
            </wv-row>
        </div>
    </div>

    <!-- Help Information -->
    <div class="alert alert-info small">
        <h6 class="alert-heading"><i class="fas fa-info-circle mr-2"></i>Component Information</h6>
        <hr class="my-2">
        <p class="mb-2">
            <strong>Approval Dashboard</strong> displays real-time team performance metrics for managers.
        </p>
        <p class="mb-2">
            <strong>Available Metrics:</strong>
        </p>
        <ul class="mb-2">
            <li><code>pending</code> - Count of approval requests awaiting action</li>
            <li><code>avg_time</code> - Average time to process approvals</li>
            <li><code>approval_rate</code> - Percentage of approved vs. rejected requests</li>
            <li><code>overdue</code> - Count of requests past their deadline</li>
            <li><code>recent</code> - Recent activity feed (last 5 actions)</li>
        </ul>
        <p class="mb-0">
            <strong>Access Control:</strong> Only users with Manager or Administrator roles can view the dashboard.
        </p>
    </div>
</div>
