@*
    Options.cshtml - Configuration view for PcApprovalDashboard component
    
    Provides form fields for configuring dashboard parameters in the WebVella page designer:
    - days_back: Number of days to look back for metrics calculation (default 30)
    - show_charts: Whether to display charts in the dashboard (default true)
    - refresh_interval: Auto-refresh interval in seconds, 0 = disabled (default 0)
    
    Uses WebVella wv-field tag helpers for form input controls bound to PcApprovalDashboardOptions DTO.
*@
@addTagHelper *, WebVella.Erp.Plugins.Core
@addTagHelper *, WebVella.Erp.Web
@addTagHelper *, WebVella.TagHelpers
@using WebVella.Erp.Web.Utils
@using WebVella.Erp.Web
@using WebVella.Erp.Web.Models
@using WebVella.Erp.Plugins.Approval.Components
@{
    var options = (PcApprovalDashboard.PcApprovalDashboardOptions)ViewBag.Options;
    var erpRequest = (ErpRequestContext)ViewBag.RequestContext;
}

<h4 class="mb-3">Dashboard Configuration</h4>

<wv-row>
    <wv-column span="4">
        <wv-field-number name="days_back" value="@options.DaysBack" label-text="Days Back" description="Number of days to look back for metrics calculation. Default is 30 days."></wv-field-number>
    </wv-column>
    <wv-column span="4">
        <wv-field-number name="refresh_interval" value="@options.RefreshInterval" label-text="Refresh Interval (seconds)" description="Auto-refresh interval in seconds. Set to 0 to disable auto-refresh."></wv-field-number>
    </wv-column>
    <wv-column span="4">
        <wv-field-checkbox name="show_charts" value="@options.ShowCharts" label-text="Show Charts" text-true="Display visual charts on the dashboard"></wv-field-checkbox>
    </wv-column>
</wv-row>

<wv-row class="mt-3">
    <wv-column span="12">
        <div class="go-bkg-gray-light border p-2">
            <span class="go-blue"><i class="fa fa-info-circle"></i> Note: </span>
            The Approval Dashboard displays real-time metrics including pending count, average approval time, 
            approval rate percentage, overdue count, and total processed requests. Configure the parameters 
            above to customize the dashboard display for your workflow management needs.
        </div>
    </wv-column>
</wv-row>
