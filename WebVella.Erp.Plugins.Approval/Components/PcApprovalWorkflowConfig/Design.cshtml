@*
    Design.cshtml - Page builder preview for PcApprovalWorkflowConfig component
    
    Displays a static representation of the workflow configuration component
    for visual identification during page design.
    
    STORY-008: UI components must support Design render mode
*@
@addTagHelper *, WebVella.Erp.Plugins.Core
@addTagHelper *, WebVella.Erp.Web
@addTagHelper *, WebVella.TagHelpers
@using WebVella.Erp.Web.Models;
@using WebVella.Erp.Plugins.Approval.Components;

<div class="p-2">
    <div class="card">
        <div class="card-header bg-light d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0">
                <i class="fas fa-cogs mr-2"></i>Approval Workflow Configuration
            </h5>
            <span class="badge badge-secondary">Design Preview</span>
        </div>
        <div class="card-body p-3">
            <p class="text-muted mb-3">
                Manage approval workflow definitions, steps, and rules.
            </p>
            
            @* Sample workflow table preview *@
            <table class="table table-sm table-bordered mb-0">
                <thead class="thead-light">
                    <tr>
                        <th>Name</th>
                        <th>Target Entity</th>
                        <th class="text-center">Status</th>
                        <th class="text-center">Steps</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><strong>Purchase Order Approval</strong></td>
                        <td><code>purchase_order</code></td>
                        <td class="text-center"><span class="badge badge-success">Enabled</span></td>
                        <td class="text-center"><span class="badge badge-info">3</span></td>
                        <td class="text-center">
                            <i class="fas fa-edit text-primary mr-1" title="Edit"></i>
                            <i class="fas fa-list-ol text-info mr-1" title="Steps"></i>
                            <i class="fas fa-trash text-danger" title="Delete"></i>
                        </td>
                    </tr>
                    <tr>
                        <td><strong>Expense Request Approval</strong></td>
                        <td><code>expense_request</code></td>
                        <td class="text-center"><span class="badge badge-secondary">Disabled</span></td>
                        <td class="text-center"><span class="badge badge-info">2</span></td>
                        <td class="text-center">
                            <i class="fas fa-edit text-primary mr-1" title="Edit"></i>
                            <i class="fas fa-list-ol text-info mr-1" title="Steps"></i>
                            <i class="fas fa-trash text-danger" title="Delete"></i>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        <div class="card-footer text-muted text-center small">
            <i class="fas fa-info-circle mr-1"></i>
            Runtime: Displays interactive workflow management interface
        </div>
    </div>
</div>
