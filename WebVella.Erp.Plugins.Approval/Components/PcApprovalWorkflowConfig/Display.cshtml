    /**
     * Save workflow (create or update)
     * @@param {string} componentId - The unique component instance ID
     * @@param {Event} event - The form submit event
     * @@returns {boolean} - Always returns false to prevent form submission
     */
    window.WvApprovalWorkflowConfig.saveWorkflow = function(componentId, event) {
        event.preventDefault();
        
        var workflowId = document.getElementById(componentId + '-workflow-id').value;
        var isEdit = !!workflowId;
        
        // Gather form data
        var data = {
            name: document.getElementById(componentId + '-workflow-name').value.trim(),
            target_entity: document.getElementById(componentId + '-target-entity').value.trim(),
            is_enabled: document.getElementById(componentId + '-is-enabled').checked
        };
        
        // Validate
        if (!data.name) {
            showFormError(componentId, 'Workflow name is required.');
            return false;
        }
        if (!data.target_entity) {
            showFormError(componentId, 'Target entity name is required.');
            return false;
        }
        
        // Set up AJAX request
        var url = isEdit ? API_BASE_URL + '/' + workflowId : API_BASE_URL;
        var method = isEdit ? 'PUT' : 'POST';
        
        $.ajax({
            url: url,
            type: method,
            contentType: 'application/json',
            data: JSON.stringify(data),
            success: function(response) {
                if (response.success) {
                    toastr.success(isEdit ? 'Workflow updated successfully' : 'Workflow created successfully');
                    $('#' + componentId + '-workflow-modal').modal('hide');
                    // Reload workflows
                    reloadWorkflows(componentId);
                } else {
                    showFormError(componentId, response.message || 'An error occurred while saving the workflow.');
                }
            },
            error: function(xhr) {
                var errorMsg = 'An error occurred while saving the workflow.';
                if (xhr.responseJSON && xhr.responseJSON.message) {
                    errorMsg = xhr.responseJSON.message;
                }
                showFormError(componentId, errorMsg);
            }
        });
        
        return false;
    };
    
