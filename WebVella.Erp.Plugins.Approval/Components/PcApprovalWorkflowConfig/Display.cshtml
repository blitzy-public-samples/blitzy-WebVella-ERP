    /**
     * Render steps list
     */
    function renderStepsList(componentId, steps) {
        var listContainer = document.getElementById(componentId + '-steps-list');
        
        if (!steps || steps.length === 0) {
            listContainer.innerHTML = '<div class="alert alert-info mb-0"><i class="fas fa-info-circle mr-2"></i>No steps configured. Click "Add Step" to create the first step.</div>';
            return;
        }
        
        var html = '';
        steps.sort(function(a, b) { return a.step_order - b.step_order; });
        
        steps.forEach(function(step) {
            // HTML-encode the JSON to safely embed in onclick attribute
            // Replace " with &quot; so HTML parser doesn't treat them as attribute delimiters
            var stepJson = JSON.stringify(step).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/'/g, '&#39;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
            
            html += '<div class="list-group-item d-flex justify-content-between align-items-center">' +
                '<div>' +
                    '<strong>#' + step.step_order + ' - ' + escapeHtml(step.name) + '</strong>' +
                    '<br><small class="text-muted">' +
                        'Type: ' + escapeHtml(step.approver_type) + 
                        (step.timeout_hours ? ' | Timeout: ' + step.timeout_hours + 'h' : '') +
                        (step.is_final ? ' | <span class="badge badge-primary">Final Step</span>' : '') +
                    '</small>' +
                '</div>' +
                '<div class="btn-group btn-group-sm">' +
                    '<button type="button" class="btn btn-outline-primary" title="Edit" ' +
                        'onclick="window.WvApprovalWorkflowConfig.editStep(\'' + componentId + '\', ' + stepJson + ')">' +
                        '<i class="fas fa-edit"></i>' +
                    '</button>' +
                    '<button type="button" class="btn btn-outline-danger" title="Delete" ' +
                        'onclick="window.WvApprovalWorkflowConfig.deleteStep(\'' + componentId + '\', \'' + step.id + '\')">' +
                        '<i class="fas fa-trash"></i>' +
                    '</button>' +
                '</div>' +
            '</div>';
        });
        
        listContainer.innerHTML = html;
    }
    
