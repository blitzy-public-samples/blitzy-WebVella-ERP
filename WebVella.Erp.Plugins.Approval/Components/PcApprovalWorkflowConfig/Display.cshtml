@*
    Display.cshtml - Runtime display view for PcApprovalWorkflowConfig component
    
    Provides the administrative interface for managing approval workflow definitions.
    Features:
    - Workflow list table with CRUD operations
    - Enable/disable workflow toggles
    - Links to step and rule configuration
    - Create/Edit modal form
    - Delete confirmation modal
    
    STORY-008: PcApprovalWorkflowConfig component must provide runtime display for CRUD workflow operations
*@
@addTagHelper *, WebVella.Erp.Plugins.Core
@addTagHelper *, WebVella.Erp.Web
@addTagHelper *, WebVella.TagHelpers
@using WebVella.Erp.Web.Utils
@using WebVella.Erp.Web
@using WebVella.Erp.Web.Models
@using WebVella.Erp.Plugins.Approval.Components
@using Newtonsoft.Json
@{
    // Cast ViewBag values to strongly-typed variables
    var options = (PcApprovalWorkflowConfig.PcApprovalWorkflowConfigOptions)ViewBag.Options;
    var node = (PageBodyNode)ViewBag.Node;
    var erpRequest = (ErpRequestContext)ViewBag.RequestContext;
    var componentMeta = ViewBag.ComponentMeta;
    var workflowsJson = (string)ViewBag.WorkflowsJson ?? "[]";
    var currentUserJson = (string)ViewBag.CurrentUserJson ?? "{}";
    
    // Generate unique component instance ID for JavaScript binding
    var componentId = "wv-approval-workflow-config-" + Guid.NewGuid().ToString("N").Substring(0, 8);
}

<div id="@componentId" class="wv-approval-workflow-config" data-workflows='@workflowsJson'>
    @* ================== HEADER SECTION ================== *@
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0">
                <i class="fas fa-cogs mr-2"></i>Approval Workflow Configuration
            </h5>
            <div class="d-flex align-items-center">
                @* Status Filter Dropdown *@
                <div class="mr-2">
                    <select id="@(componentId)-status-filter" class="form-control form-control-sm" 
                            onchange="window.WvApprovalWorkflowConfig.filterByStatus('@componentId', this.value)"
                            style="min-width: 130px;">
                        <option value="all" selected>All Workflows</option>
                        <option value="enabled">Enabled Only</option>
                        <option value="disabled">Disabled Only</option>
                    </select>
                </div>
                <button type="button" class="btn btn-sm btn-success" 
                        data-toggle="modal" 
                        data-target="#@(componentId)-workflow-modal"
                        onclick="window.WvApprovalWorkflowConfig.openCreateModal('@componentId')">
                    <i class="fas fa-plus mr-1"></i>Add Workflow
                </button>
            </div>
        </div>
        
        <div class="card-body p-0">
            @* ================== WORKFLOW TABLE ================== *@
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0" id="@(componentId)-table">
                    <thead class="thead-light">
                        <tr>
                            <th scope="col">Name</th>
                            <th scope="col">Target Entity</th>
                            <th scope="col" class="text-center" style="width: 100px;">Status</th>
                            <th scope="col" class="text-center" style="width: 80px;">Steps</th>
                            <th scope="col" class="text-center" style="width: 80px;">Rules</th>
                            <th scope="col" style="width: 140px;">Created On</th>
                            <th scope="col" class="text-center" style="width: 180px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="@(componentId)-tbody">
                        @* Workflow rows will be populated via JavaScript from workflowsJson *@
                    </tbody>
                </table>
            </div>
            
            @* ================== EMPTY STATE ================== *@
            <div id="@(componentId)-empty" class="alert alert-info m-3" style="display: none;">
                <i class="fas fa-info-circle mr-2"></i>
                No approval workflows configured. Click <strong>Add Workflow</strong> to create your first workflow.
            </div>
        </div>
    </div>
    
    @* ================== CREATE/EDIT WORKFLOW MODAL ================== *@
    <div class="modal fade" id="@(componentId)-workflow-modal" tabindex="-1" role="dialog" 
         aria-labelledby="@(componentId)-workflow-modal-label" aria-hidden="true">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="@(componentId)-workflow-modal-label">
                        <i class="fas fa-cogs mr-2"></i>
                        <span id="@(componentId)-modal-title">Create Workflow</span>
                    </h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <form id="@(componentId)-workflow-form" onsubmit="return window.WvApprovalWorkflowConfig.saveWorkflow('@componentId', event)">
                    <div class="modal-body">
                        @* Hidden field for workflow ID (used during edit) *@
                        <input type="hidden" id="@(componentId)-workflow-id" name="id" value="">
                        
                        @* Workflow Name Field *@
                        <div class="form-group">
                            <label for="@(componentId)-workflow-name" class="font-weight-bold">
                                Workflow Name <span class="text-danger">*</span>
                            </label>
                            <input type="text" 
                                   class="form-control" 
                                   id="@(componentId)-workflow-name" 
                                   name="name" 
                                   placeholder="Enter workflow name (e.g., Purchase Order Approval)"
                                   maxlength="256"
                                   required>
                            <small class="form-text text-muted">
                                A descriptive name for this approval workflow. Maximum 256 characters.
                            </small>
                        </div>
                        
                        @* Target Entity Name Field *@
                        <div class="form-group">
                            <label for="@(componentId)-target-entity" class="font-weight-bold">
                                Target Entity <span class="text-danger">*</span>
                            </label>
                            <input type="text" 
                                   class="form-control" 
                                   id="@(componentId)-target-entity" 
                                   name="target_entity" 
                                   placeholder="Enter entity name (e.g., purchase_order)"
                                   maxlength="128"
                                   required>
                            <small class="form-text text-muted">
                                The system name of the entity that will trigger this approval workflow. Maximum 128 characters.
                            </small>
                        </div>
                        
                        @* Is Enabled Checkbox *@
                        <div class="form-group">
                            <div class="custom-control custom-switch">
                                <input type="checkbox" 
                                       class="custom-control-input" 
                                       id="@(componentId)-is-enabled" 
                                       name="is_enabled"
                                       checked>
                                <label class="custom-control-label font-weight-bold" for="@(componentId)-is-enabled">
                                    Workflow Enabled
                                </label>
                            </div>
                            <small class="form-text text-muted">
                                When enabled, this workflow will automatically trigger for new records of the target entity.
                            </small>
                        </div>
                        
                        @* Validation Error Display *@
                        <div id="@(componentId)-form-errors" class="alert alert-danger" style="display: none;">
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">
                            <i class="fas fa-times mr-1"></i>Cancel
                        </button>
                        <button type="submit" class="btn btn-primary" id="@(componentId)-save-btn">
                            <i class="fas fa-save mr-1"></i>
                            <span id="@(componentId)-save-btn-text">Create Workflow</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    @* ================== DELETE CONFIRMATION MODAL ================== *@
    <div class="modal fade" id="@(componentId)-delete-modal" tabindex="-1" role="dialog" 
         aria-labelledby="@(componentId)-delete-modal-label" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title" id="@(componentId)-delete-modal-label">
                        <i class="fas fa-exclamation-triangle mr-2"></i>Confirm Delete
                    </h5>
                    <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="@(componentId)-delete-workflow-id" value="">
                    <p class="mb-0">
                        Are you sure you want to delete the workflow 
                        <strong id="@(componentId)-delete-workflow-name"></strong>?
                    </p>
                    <p class="text-danger mt-2 mb-0">
                        <i class="fas fa-warning mr-1"></i>
                        This action cannot be undone. All associated steps, rules, and pending approval requests will be affected.
                    </p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">
                        <i class="fas fa-times mr-1"></i>Cancel
                    </button>
                    <button type="button" class="btn btn-danger" 
                            onclick="window.WvApprovalWorkflowConfig.confirmDelete('@componentId')">
                        <i class="fas fa-trash mr-1"></i>Delete Workflow
                    </button>
                </div>
            </div>
        </div>
    </div>
    
    @* ================== STEPS CONFIGURATION MODAL ================== *@
    <div class="modal fade" id="@(componentId)-steps-modal" tabindex="-1" role="dialog" 
         aria-labelledby="@(componentId)-steps-modal-label" aria-hidden="true">
        <div class="modal-dialog modal-xl" role="document">
            <div class="modal-content">
                <div class="modal-header bg-info text-white">
                    <h5 class="modal-title" id="@(componentId)-steps-modal-label">
                        <i class="fas fa-list-ol mr-2"></i>Configure Steps for: <span id="@(componentId)-steps-workflow-name"></span>
                    </h5>
                    <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="@(componentId)-steps-workflow-id" value="">
                    
                    @* Add Step Button *@
                    <div class="mb-3">
                        <button type="button" class="btn btn-sm btn-success" 
                                onclick="window.WvApprovalWorkflowConfig.openAddStepForm('@componentId')">
                            <i class="fas fa-plus mr-1"></i>Add Step
                        </button>
                    </div>
                    
                    @* Steps List *@
                    <div id="@(componentId)-steps-list" class="list-group">
                        <div class="text-muted text-center py-3">Loading steps...</div>
                    </div>
                    
                    @* Add/Edit Step Form (hidden by default) *@
                    <div id="@(componentId)-step-form-container" class="mt-3" style="display: none;">
                        <hr>
                        <h6 id="@(componentId)-step-form-title">Add New Step</h6>
                        <form id="@(componentId)-step-form" onsubmit="return window.WvApprovalWorkflowConfig.saveStep('@componentId', event)">
                            <input type="hidden" id="@(componentId)-step-id" value="">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="@(componentId)-step-name">Step Name <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control form-control-sm" id="@(componentId)-step-name" 
                                               placeholder="e.g., Manager Approval" maxlength="256" required>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label for="@(componentId)-step-approver-type">Approver Type <span class="text-danger">*</span></label>
                                        <select class="form-control form-control-sm" id="@(componentId)-step-approver-type" required>
                                            <option value="role">Role</option>
                                            <option value="user">Specific User</option>
                                            <option value="department_head">Department Head</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label for="@(componentId)-step-timeout">Timeout (Hours)</label>
                                        <input type="number" class="form-control form-control-sm" id="@(componentId)-step-timeout" 
                                               placeholder="Optional" min="1">
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="@(componentId)-step-approver-id">Approver ID (Role/User GUID)</label>
                                        <input type="text" class="form-control form-control-sm" id="@(componentId)-step-approver-id" 
                                               placeholder="Leave empty for department_head type">
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label for="@(componentId)-step-order">Step Order <span class="text-danger">*</span></label>
                                        <input type="number" class="form-control form-control-sm" id="@(componentId)-step-order" 
                                               value="1" min="1" required>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group pt-4">
                                        <div class="custom-control custom-checkbox">
                                            <input type="checkbox" class="custom-control-input" id="@(componentId)-step-is-final">
                                            <label class="custom-control-label" for="@(componentId)-step-is-final">Final Step</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="btn-group btn-group-sm">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save mr-1"></i>Save Step
                                </button>
                                <button type="button" class="btn btn-secondary" onclick="window.WvApprovalWorkflowConfig.cancelStepForm('@componentId')">
                                    <i class="fas fa-times mr-1"></i>Cancel
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">
                        <i class="fas fa-times mr-1"></i>Close
                    </button>
                </div>
            </div>
        </div>
    </div>
    
    @* ================== RULES CONFIGURATION MODAL ================== *@
    <div class="modal fade" id="@(componentId)-rules-modal" tabindex="-1" role="dialog" 
         aria-labelledby="@(componentId)-rules-modal-label" aria-hidden="true">
        <div class="modal-dialog modal-xl" role="document">
            <div class="modal-content">
                <div class="modal-header bg-secondary text-white">
                    <h5 class="modal-title" id="@(componentId)-rules-modal-label">
                        <i class="fas fa-filter mr-2"></i>Configure Rules for: <span id="@(componentId)-rules-workflow-name"></span>
                    </h5>
                    <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="@(componentId)-rules-workflow-id" value="">
                    
                    @* Add Rule Button *@
                    <div class="mb-3">
                        <button type="button" class="btn btn-sm btn-success" 
                                onclick="window.WvApprovalWorkflowConfig.openAddRuleForm('@componentId')">
                            <i class="fas fa-plus mr-1"></i>Add Rule
                        </button>
                    </div>
                    
                    @* Rules List *@
                    <div id="@(componentId)-rules-list" class="list-group">
                        <div class="text-muted text-center py-3">Loading rules...</div>
                    </div>
                    
                    @* Add/Edit Rule Form (hidden by default) *@
                    <div id="@(componentId)-rule-form-container" class="mt-3" style="display: none;">
                        <hr>
                        <h6 id="@(componentId)-rule-form-title">Add New Rule</h6>
                        <form id="@(componentId)-rule-form" onsubmit="return window.WvApprovalWorkflowConfig.saveRule('@componentId', event)">
                            <input type="hidden" id="@(componentId)-rule-id" value="">
                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label for="@(componentId)-rule-name">Rule Name <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control form-control-sm" id="@(componentId)-rule-name" 
                                               placeholder="e.g., High Value Purchase" maxlength="256" required>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label for="@(componentId)-rule-field">Field Name <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control form-control-sm" id="@(componentId)-rule-field" 
                                               placeholder="e.g., amount, total" maxlength="128" required>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <div class="form-group">
                                        <label for="@(componentId)-rule-operator">Operator <span class="text-danger">*</span></label>
                                        <select class="form-control form-control-sm" id="@(componentId)-rule-operator" required>
                                            <option value="eq">Equals (=)</option>
                                            <option value="neq">Not Equals (!=)</option>
                                            <option value="gt">Greater Than (&gt;)</option>
                                            <option value="gte">Greater or Equal (&gt;=)</option>
                                            <option value="lt">Less Than (&lt;)</option>
                                            <option value="lte">Less or Equal (&lt;=)</option>
                                            <option value="contains">Contains</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <div class="form-group">
                                        <label for="@(componentId)-rule-priority">Priority</label>
                                        <input type="number" class="form-control form-control-sm" id="@(componentId)-rule-priority" 
                                               value="0" min="0">
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-8">
                                    <div class="form-group">
                                        <label for="@(componentId)-rule-value">Value <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control form-control-sm" id="@(componentId)-rule-value" 
                                               placeholder="e.g., 1000" maxlength="1024" required>
                                    </div>
                                </div>
                            </div>
                            <div class="btn-group btn-group-sm">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save mr-1"></i>Save Rule
                                </button>
                                <button type="button" class="btn btn-secondary" onclick="window.WvApprovalWorkflowConfig.cancelRuleForm('@componentId')">
                                    <i class="fas fa-times mr-1"></i>Cancel
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">
                        <i class="fas fa-times mr-1"></i>Close
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@* ================== COMPONENT JAVASCRIPT ================== *@
@* Reference external service.js for page builder lifecycle events *@
<script src="/_content/WebVella.Erp.Plugins.Approval/Components/PcApprovalWorkflowConfig/service.js"></script>
<script>
(function() {
    'use strict';
    
    // Create global namespace for approval workflow config if not exists
    window.WvApprovalWorkflowConfig = window.WvApprovalWorkflowConfig || {};
    
    // API base URL for approval workflows
    var API_BASE_URL = '/api/v3.0/p/approval/workflow';
    
    /**
     * Initialize the workflow config component
     * @@param {string} componentId - The unique component instance ID
     */
    window.WvApprovalWorkflowConfig.init = function(componentId) {
        var container = document.getElementById(componentId);
        if (!container) {
            console.error('WvApprovalWorkflowConfig: Container not found:', componentId);
            return;
        }
        
        // Parse workflows from data attribute
        var workflowsJson = container.getAttribute('data-workflows') || '[]';
        var workflows = [];
        try {
            workflows = JSON.parse(workflowsJson);
        } catch (e) {
            console.error('WvApprovalWorkflowConfig: Failed to parse workflows JSON:', e);
            workflows = [];
        }
        
        // Store ALL workflows in container (never filtered from server)
        container._workflows = workflows;
        container._currentFilter = 'all';
        
        // Render the workflow table with all workflows
        renderWorkflowTable(componentId, workflows);
    };
    
    /**
     * Filter workflows by status (all, enabled, disabled)
     * @@param {string} componentId - The unique component instance ID
     * @@param {string} filterValue - 'all', 'enabled', or 'disabled'
     */
    window.WvApprovalWorkflowConfig.filterByStatus = function(componentId, filterValue) {
        var container = document.getElementById(componentId);
        if (!container) return;
        
        var workflows = container._workflows || [];
        container._currentFilter = filterValue;
        
        var filteredWorkflows = workflows;
        if (filterValue === 'enabled') {
            filteredWorkflows = workflows.filter(function(w) { return w.is_enabled === true; });
        } else if (filterValue === 'disabled') {
            filteredWorkflows = workflows.filter(function(w) { return w.is_enabled === false; });
        }
        
        renderWorkflowTable(componentId, filteredWorkflows);
    };
    
    /**
     * Render the workflow table body
     * @@param {string} componentId - The unique component instance ID
     * @@param {Array} workflows - Array of workflow objects
     */
    function renderWorkflowTable(componentId, workflows) {
        var tbody = document.getElementById(componentId + '-tbody');
        var emptyDiv = document.getElementById(componentId + '-empty');
        
        if (!tbody) return;
        
        // Clear existing rows
        tbody.innerHTML = '';
        
        // Show/hide empty state
        if (!workflows || workflows.length === 0) {
            emptyDiv.style.display = 'block';
            return;
        }
        emptyDiv.style.display = 'none';
        
        // Render each workflow row
        workflows.forEach(function(workflow) {
            var row = document.createElement('tr');
            row.setAttribute('data-workflow-id', workflow.id);
            
            // Status badge class and text
            var statusBadgeClass = workflow.is_enabled ? 'badge-success' : 'badge-secondary';
            var statusText = workflow.is_enabled ? 'Enabled' : 'Disabled';
            
            // Format created date
            var createdOn = workflow.created_on ? new Date(workflow.created_on).toLocaleDateString() : 'N/A';
            
            // Steps and rules count (these would come from the API if available)
            var stepsCount = workflow.steps_count !== undefined ? workflow.steps_count : '-';
            var rulesCount = workflow.rules_count !== undefined ? workflow.rules_count : '-';
            
            row.innerHTML = 
                '<td class="align-middle">' +
                    '<strong>' + escapeHtml(workflow.name) + '</strong>' +
                '</td>' +
                '<td class="align-middle">' +
                    '<code>' + escapeHtml(workflow.target_entity) + '</code>' +
                '</td>' +
                '<td class="align-middle text-center">' +
                    '<span class="badge ' + statusBadgeClass + '">' + statusText + '</span>' +
                '</td>' +
                '<td class="align-middle text-center">' +
                    '<span class="badge badge-info">' + stepsCount + '</span>' +
                '</td>' +
                '<td class="align-middle text-center">' +
                    '<span class="badge badge-info">' + rulesCount + '</span>' +
                '</td>' +
                '<td class="align-middle">' +
                    '<small>' + createdOn + '</small>' +
                '</td>' +
                '<td class="align-middle text-center">' +
                    '<div class="btn-group btn-group-sm" role="group">' +
                        '<button type="button" class="btn btn-outline-primary" ' +
                                'title="Edit Workflow" ' +
                                'onclick="window.WvApprovalWorkflowConfig.openEditModal(\'' + componentId + '\', \'' + workflow.id + '\')">' +
                            '<i class="fas fa-edit"></i>' +
                        '</button>' +
                        '<button type="button" class="btn btn-outline-' + (workflow.is_enabled ? 'warning' : 'success') + '" ' +
                                'title="' + (workflow.is_enabled ? 'Disable' : 'Enable') + ' Workflow" ' +
                                'onclick="window.WvApprovalWorkflowConfig.toggleStatus(\'' + componentId + '\', \'' + workflow.id + '\', ' + !workflow.is_enabled + ')">' +
                            '<i class="fas fa-' + (workflow.is_enabled ? 'pause' : 'play') + '"></i>' +
                        '</button>' +
                        '<button type="button" class="btn btn-outline-info" ' +
                                'title="Configure Steps" ' +
                                'onclick="window.WvApprovalWorkflowConfig.configureSteps(\'' + componentId + '\', \'' + workflow.id + '\', \'' + escapeHtml(workflow.name).replace(/'/g, "\\'") + '\')">' +
                            '<i class="fas fa-list-ol"></i>' +
                        '</button>' +
                        '<button type="button" class="btn btn-outline-secondary" ' +
                                'title="Configure Rules" ' +
                                'onclick="window.WvApprovalWorkflowConfig.configureRules(\'' + componentId + '\', \'' + workflow.id + '\', \'' + escapeHtml(workflow.name).replace(/'/g, "\\'") + '\')">' +
                            '<i class="fas fa-sliders-h"></i>' +
                        '</button>' +
                        '<button type="button" class="btn btn-outline-danger" ' +
                                'title="Delete Workflow" ' +
