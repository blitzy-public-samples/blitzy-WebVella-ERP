    /**
     * Reload workflows from API
     * @@param {string} componentId - The unique component instance ID
     */
    function reloadWorkflows(componentId) {
        $.ajax({
            url: API_BASE_URL,
            type: 'GET',
            success: function(response) {
                if (response.success && response.object) {
                    var container = document.getElementById(componentId);
                    var workflows = response.object;
                    
                    // Store ALL workflows (server returns all workflows including disabled)
                    container._workflows = workflows;
                    
                    // Re-apply the current filter
                    var currentFilter = container._currentFilter || 'all';
                    var filteredWorkflows = workflows;
                    
                    if (currentFilter === 'enabled') {
                        filteredWorkflows = workflows.filter(function(w) { return w.is_enabled === true; });
                    } else if (currentFilter === 'disabled') {
                        filteredWorkflows = workflows.filter(function(w) { return w.is_enabled === false; });
                    }
                    
                    renderWorkflowTable(componentId, filteredWorkflows);
                } else {
                    toastr.error('Failed to reload workflows');
                }
            },
            error: function() {
                toastr.error('Failed to reload workflows');
            }
        });
    }
    
