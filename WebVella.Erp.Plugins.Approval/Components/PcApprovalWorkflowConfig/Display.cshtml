<script src="/_content/WebVella.Erp.Plugins.Approval/Components/PcApprovalWorkflowConfig/service.js"></script>
<script>
(function() {
    // Initialize component-specific data
    var componentId = '@componentId';
    var container = document.getElementById('wf-config-' + componentId);
    
    if (container && typeof ApprovalWorkflowConfig !== 'undefined') {
        // Component data is stored in data attributes for access by service.js
        ApprovalWorkflowConfig.init(componentId, {
            workflows: @Html.Raw(workflowsJson),
            approverTypes: @Html.Raw(approverTypesJson),
            ruleOperators: @Html.Raw(ruleOperatorsJson),
            currentUser: @Html.Raw(currentUserJson),
            siteRootUrl: '@siteRootUrl',
            workflowModalId: '@workflowModalId',
            stepModalId: '@stepModalId',
            ruleModalId: '@ruleModalId',
            deleteConfirmModalId: '@deleteConfirmModalId'
        });
    }
})();
</script>
