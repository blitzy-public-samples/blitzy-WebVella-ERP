    /**
     * Render rules list
     */
    function renderRulesList(componentId, rules) {
        var listContainer = document.getElementById(componentId + '-rules-list');
        
        if (!rules || rules.length === 0) {
            listContainer.innerHTML = '<div class="alert alert-info mb-0"><i class="fas fa-info-circle mr-2"></i>No rules configured. Click "Add Rule" to create the first rule.</div>';
            return;
        }
        
        var operatorLabels = {
            'eq': '=', 'neq': '!=', 'gt': '>', 'gte': '>=', 'lt': '<', 'lte': '<=', 'contains': 'contains'
        };
        
        var html = '';
        rules.sort(function(a, b) { return (b.priority || 0) - (a.priority || 0); });
        
        rules.forEach(function(rule) {
            // HTML-encode the JSON to safely embed in onclick attribute
            // Replace " with &quot; so HTML parser doesn't treat them as attribute delimiters
            var ruleJson = JSON.stringify(rule).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/'/g, '&#39;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
            
            html += '<div class="list-group-item d-flex justify-content-between align-items-center">' +
                '<div>' +
                    '<strong>' + escapeHtml(rule.name) + '</strong>' +
                    '<br><small class="text-muted">' +
                        '<code>' + escapeHtml(rule.field_name) + '</code> ' + 
                        (operatorLabels[rule.operator] || rule.operator) + 
                        ' <code>' + escapeHtml(rule.value) + '</code>' +
                        ' | Priority: ' + (rule.priority || 0) +
                    '</small>' +
                '</div>' +
                '<div class="btn-group btn-group-sm">' +
                    '<button type="button" class="btn btn-outline-primary" title="Edit" ' +
                        'onclick="window.WvApprovalWorkflowConfig.editRule(\'' + componentId + '\', ' + ruleJson + ')">' +
                        '<i class="fas fa-edit"></i>' +
                    '</button>' +
                    '<button type="button" class="btn btn-outline-danger" title="Delete" ' +
                        'onclick="window.WvApprovalWorkflowConfig.deleteRule(\'' + componentId + '\', \'' + rule.id + '\')">' +
                        '<i class="fas fa-trash"></i>' +
                    '</button>' +
                '</div>' +
            '</div>';
        });
        
        listContainer.innerHTML = html;
    }
    
