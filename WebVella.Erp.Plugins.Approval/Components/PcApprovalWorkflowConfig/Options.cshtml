@*
    Options.cshtml - Component options editor view for PcApprovalWorkflowConfig
    
    Purpose: Provides configuration interface for the Approval Workflow Config component
    in the page-builder options panel. Allows administrators to set default view mode,
    filter settings, pagination size, and workflow selection preferences.
    
    Requirements: STORY-008 - UI component specifications
*@
@addTagHelper *, WebVella.Erp.Plugins.Core
@addTagHelper *, WebVella.Erp.Web
@addTagHelper *, WebVella.TagHelpers
@using WebVella.Erp.Web.Utils;
@using WebVella.Erp.Web;
@using WebVella.Erp.Web.Models;
@using WebVella.Erp.Api.Models;
@using WebVella.Erp.Plugins.Approval.Components;
@{
    // Cast ViewBag data to strongly typed objects
    var options = (PcApprovalWorkflowConfig.PcApprovalWorkflowConfigOptions)ViewBag.Options;
    var node = (PageBodyNode)ViewBag.Node;
    var erpRequest = (ErpRequestContext)ViewBag.RequestContext;

    // Define select options for view mode (list or grid)
    var viewModeOptions = new List<SelectOption>
    {
        new SelectOption { Value = "list", Label = "List View" },
        new SelectOption { Value = "grid", Label = "Grid View" }
    };
}

@* Filter Entity Option - Text field to filter workflows by entity name *@
<wv-row>
    <wv-column span="6">
        <wv-field-text 
            name="filter_entity" 
            value="@options.FilterEntity" 
            label-text="Filter by Entity" 
            placeholder="Enter entity name to filter workflows">
        </wv-field-text>
    </wv-column>
    <wv-column span="6">
        <wv-field-checkbox 
            name="show_inactive" 
            value="@options.ShowInactive" 
            label-text="Show Inactive" 
            text-true="Include inactive workflows">
        </wv-field-checkbox>
    </wv-column>
</wv-row>

@* Default View and Page Size Options *@
<wv-row>
    <wv-column span="6">
        <wv-field-select 
            name="default_view" 
            value="@options.DefaultView" 
            label-text="Default View Mode" 
            options="@viewModeOptions.ToWvSelectOption()">
        </wv-field-select>
    </wv-column>
    <wv-column span="6">
        <wv-field-number 
            name="page_size" 
            value="@options.PageSize" 
            label-text="Page Size" 
            min="1" 
            max="100" 
            placeholder="Number of workflows per page">
        </wv-field-number>
    </wv-column>
</wv-row>

@* Help text for administrators *@
<div class="alert alert-info p-2 mt-3">
    <small>
        <i class="fas fa-info-circle me-1"></i>
        <strong>Options Guide:</strong>
        <ul class="mb-0 mt-1">
            <li><strong>Filter by Entity:</strong> Leave empty to show all workflows, or enter an entity name to filter.</li>
            <li><strong>Show Inactive:</strong> Enable to include deactivated workflows in the list.</li>
            <li><strong>Default View Mode:</strong> Choose between list (table) or grid (card) layout.</li>
            <li><strong>Page Size:</strong> Number of workflows to display per page (1-100).</li>
        </ul>
    </small>
</div>
