<Project Sdk="Microsoft.NET.Sdk.Razor">

	<PropertyGroup>
		<TargetFramework>net9.0</TargetFramework>
		<AddRazorSupportForMvc>true</AddRazorSupportForMvc>
		<SatelliteResourceLanguages>en</SatelliteResourceLanguages>
	</PropertyGroup>

	<!-- Exclude ad-hoc test files and test project files from compilation -->
	<ItemGroup>
		<Compile Remove="blitzy_adhoc_test_*.cs" />
	</ItemGroup>

	<ItemGroup>
		<FrameworkReference Include="Microsoft.AspNetCore.App" />
	</ItemGroup>

	<!-- Embedded resources for component JavaScript files - conditionally included when files exist -->
	<ItemGroup Condition="Exists('Components\PcApprovalWorkflowConfig\service.js')">
		<None Remove="Components\PcApprovalWorkflowConfig\service.js" />
		<EmbeddedResource Include="Components\PcApprovalWorkflowConfig\service.js" />
	</ItemGroup>

	<ItemGroup Condition="Exists('Components\PcApprovalRequestList\service.js')">
		<None Remove="Components\PcApprovalRequestList\service.js" />
		<EmbeddedResource Include="Components\PcApprovalRequestList\service.js" />
	</ItemGroup>

	<ItemGroup Condition="Exists('Components\PcApprovalAction\service.js')">
		<None Remove="Components\PcApprovalAction\service.js" />
		<EmbeddedResource Include="Components\PcApprovalAction\service.js" />
	</ItemGroup>

	<ItemGroup Condition="Exists('Components\PcApprovalHistory\service.js')">
		<None Remove="Components\PcApprovalHistory\service.js" />
		<EmbeddedResource Include="Components\PcApprovalHistory\service.js" />
	</ItemGroup>

	<ItemGroup Condition="Exists('Components\PcApprovalDashboard\service.js')">
		<None Remove="Components\PcApprovalDashboard\service.js" />
		<EmbeddedResource Include="Components\PcApprovalDashboard\service.js" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.AspNetCore.Mvc.NewtonsoftJson" Version="9.0.10" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\WebVella.Erp.Web\WebVella.Erp.Web.csproj" />
		<ProjectReference Include="..\WebVella.ERP\WebVella.Erp.csproj" />
	</ItemGroup>
</Project>
