@page
@model WebVella.Erp.Site.Pages.ErrorModel
@{
	@*
		QA Issue 14 (MINOR visual) and Issue 20 (MINOR functional) fix: Error page
		now uses _SystemMaster layout so the Roboto theme/Bootstrap CSS/JS bundle
		loads, the page no longer renders in browser-default Times New Roman, and
		the user has a "Return to Home" recovery affordance. Per AAP §0.11.1.2 the
		HTTP status codes returned by the page are unchanged (401/404/500/default
		are still emitted), and the page route remains "/error".
	*@
	Layout = "~/Pages/_SystemMaster.cshtml";
	var statusCode = HttpContext.Response.StatusCode;
	string statusTitle;
	string statusBody;
	string statusIcon;
	switch (statusCode)
	{
		case 401:
			ViewData["Title"] = "401 Access Denied";
			statusTitle = "Access Denied";
			statusBody = "You do not have permission to view the requested page or resource.";
			statusIcon = "fa-lock";
			break;
		case 404:
			ViewData["Title"] = "404 Not Found";
			statusTitle = "Not Found";
			statusBody = "The page or resource you requested could not be found.";
			statusIcon = "fa-search";
			break;
		case 500:
			ViewData["Title"] = "500 Server Error";
			statusTitle = "Server Error";
			statusBody = "An unexpected system error occurred. Please try again later.";
			statusIcon = "fa-exclamation-triangle";
			break;
		default:
			ViewData["Title"] = "Error";
			statusTitle = "Unexpected Error";
			statusBody = "An unexpected error occurred while processing your request.";
			statusIcon = "fa-exclamation-circle";
			break;
	}
}

<div class="container">
	<div class="row justify-content-center mt-5">
		<div class="col-auto" style="max-width:500px;">
			<div class="card shadow-sm">
				<div class="card-body text-center p-4">
					<div class="mb-3" style="font-size:48px; color:#dc3545;">
						<i class="fas @statusIcon" aria-hidden="true"></i>
					</div>
					<h1 class="h3 mb-3">@statusTitle</h1>
					<p class="text-muted mb-4">@statusBody</p>
					<a href="/" class="btn btn-primary btn-sm">
						<i class="fas fa-home" aria-hidden="true"></i> Return to Home
					</a>
				</div>
			</div>
		</div>
	</div>
</div>
