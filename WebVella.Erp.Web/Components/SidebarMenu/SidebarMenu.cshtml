@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, WebVella.Erp.Web
@addTagHelper *, WebVella.Controls
@using WebVella.Erp.Web.Models;
@{
	var sidebarMenu = (List<MenuItem>)ViewBag.SidebarMenu;
}
<div class="sidebar-body">
	@foreach (var menuItem in sidebarMenu)
	{
        <partial name="NavMenu" for="@menuItem"/>
		@*@Html.Partial("NavMenu", menuItem)*@
	}
</div>
<div class="sidebar-footer">
	@*
		QA Issue 6 (MAJOR a11y) fix: Icon-only buttons must expose an accessible
		name to assistive technology per WCAG 4.1.2 (Name, Role, Value, Level A).
		The icon glyph is decorative once the button has an accessible name, so we
		mark it with aria-hidden="true" so it isn't announced as duplicate text.
	*@
	<button type="button" class="btn btn-sm btn-dark sidebar-switch" aria-label="Toggle sidebar" title="Toggle sidebar">
		<i class="fas fa-fw fa-angle-double-right icon" aria-hidden="true"></i>
	</button>
</div>