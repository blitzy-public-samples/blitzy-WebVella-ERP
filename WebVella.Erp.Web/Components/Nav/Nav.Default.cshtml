@using WebVella.Erp.Web.Models;
@using Newtonsoft.Json;
@addTagHelper *, WebVella.Erp.Web
@{
	var theme = (Theme)ViewBag.Theme;
	var currentApp = (App)ViewBag.CurrentApp;
	var pageModel = (BaseErpPageModel)ViewBag.PageModel;
}
<!--c:Nav_Default-->
@*
	QA Issue 4 (MAJOR a11y) fix: top-level container is now a <nav> element so
	screen readers announce it as the "primary navigation" landmark per WCAG 2.4.1.
	QA Issue 9 (MAJOR a11y) fix: home anchor and brand-logo anchor have explicit
	aria-labels so they expose accessible names to assistive tech (WCAG 4.1.2 Name,
	Role, Value Level A). DOM IDs, classes, and behavior are otherwise preserved
	per AAP §0.11.1.2.
*@
<nav id="nav" class="pl-2 pr-2" aria-label="Primary">
	<div class="menu-nav-wrapper home">
		<div class="menu-nav">
			<a href="/" class="pl-2 pr-2" aria-label="Home" title="Home">
				<span class="fas fa-home icon" aria-hidden="true"></span>
			</a>
		</div>
	</div>
	<vc:site-menu page-model="@pageModel"></vc:site-menu>
	<div id="brand-logo" class="pl-3 pr-3">
			@if (currentApp == null)
			{
				<a href="@ViewBag.AppDefaultLink" aria-label="@ViewBag.DefaultAppName home">
					<img src="@ViewBag.BrandLogo" alt="@ViewBag.DefaultAppName logo" />
					<span class="app-label"  style="color:@ViewData["BodyBorderColor"]">@ViewBag.DefaultAppName</span>			
				</a>
			}
			else {
				<a href="@ViewBag.AppDefaultLink" aria-label="@currentApp.Label home">
					<img src="@ViewBag.BrandLogo" alt="@currentApp.Label logo" />
					<span class="app-label" title="@currentApp.Label"  style="color:@ViewData["BodyBorderColor"]">@currentApp.Label</span>			
				</a>
			}
	</div>
	<vc:application-menu page-model="@pageModel"></vc:application-menu>

	<div id="nav-right">
		<vc:user-menu page-model="@pageModel"></vc:user-menu>
		<vc:search-nav></vc:search-nav>
		<vc:user-nav></vc:user-nav>
	</div>
</nav>

@Html.Raw(ViewBag.EmbededJs)